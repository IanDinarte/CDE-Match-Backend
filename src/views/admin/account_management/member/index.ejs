<div class="search-form-container">
    <form action="/member" method="GET">
        <label>Procurar Membro</label>
        <div class="search-form">
            <input class="search-bar" type="text" name="name" placeholder="Member Name" value="<%= searchOptions.name %>">
            <button class="btn btn-primary" type="submit">Search</button>
        </div>
    </form>
</div>
<br>
<div class="row">
<% member.forEach(member=> { %>
    <div class="container">
        <div>
            <%= member.name %>
        </div>
        <div>
            <%= member.email %>
        </div>
        <div>
            <%= member.state %>
        </div>
        <a href="/admin/manage-accounts/member/<%= member.id %>">View</a>
        <a href="/admin/manage-accounts/member/<%= member.id %>/edit">Edit</a>
        <%- include('../../../partials/deleteForm.ejs', { url: `/admin/manage-accounts/member/${member.id}` }) %>
    </div>
            <% }) %>
</div>