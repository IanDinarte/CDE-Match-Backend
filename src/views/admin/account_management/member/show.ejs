<div class="profile">
    <div class="form-column">
        <div class="form-container">
            <div class="form-row">
                <div class="form-column" id="memberinfo">
                    <h2 class="name">
                        <%= member.name %>
                    </h2>
                    <div class="text-area"
                        style="color: var(--color-minor-text); font-size: var(--font-minor-text-size);">
                        <%= member.description %>
                    </div>
                    <ul>
                        <li>
                            Telemovel:
                            <span>
                                <%= member.phone %>
                            </span>
                        </li>
                        <li>
                            Email:
                            <span>
                                <%= member.email %>
                            </span>
                        </li>
                        <!-- <li>
                            Idade: 
                            <span>
                                 member.age 
                            </span>
                        </li> -->
                        <li>
                            Cidade:
                            <span>
                                <%= member.city %>
                            </span>
                        </li>
                        <li>
                            Plano do Membro:
                            <span>
                                <%= member.membership %>
                            </span>
                        </li>
                        <li>
                            Estado da Conta:
                            <span>
                                <%= member.state %>
                            </span>
                        </li>
                        <li>
                            <br>
                            <a class="btn btn-primary" href="/admin/manage-deals/?namer=<%= member.name %>">Negócios do
                                Membro</a>
                        </li>
                        <% if(member.websites.length > 0){%>
                        <br>
                        Websites:
                        <ul>
                            <% member.websites.forEach(website=> { %>
                                <li style="color: var(--color-golden)">
                                    ● 
                                    <a class="website" href="<%= website.link %>">
                                        <%= website.name %>
                                    </a>
                                </li>
                                <% }) %>
                        </ul>
                        <% } %>
                    </ul>
                </div>
                <div class="form-column">
                    <img class="profile" height="200" width="200"
                        src="<%= member.profilePicture || '/assets/default.jpg' %>" alt="Foto de <%= member.name%>">
                </div>
            </div>
            <div class="form-options">
                <a class="btn btn-primary" href="/admin/manage-accounts/member/<%= member.id %>/edit">Editar</a>
                <% if(member.state=='Inativo' ){ %>
                    <%- include('../../../partials/deleteForm.ejs', { url:
                        `/admin/manage-accounts/member/${member.id}`}) %>
                        <% } %>
            </div>
        </div>
    </div>
    <div class="form-column" style="width: 100%; display: flex; justify-content: center;">
        <div class="form-container" style="width: 100%; max-width: 500px;">
            <div class="business-list">
                <h2>Empresas do Membro</h2>
                <% member.business.forEach(business=> { %>
                    <div class="business-card">
                        <img class="logo" height="100" width="100" src="<%= business.logo || '/assets/defaultLogo.jpg' %>"
                            alt="Foto de <%= business.name%>">
                        <div class="business-info">
                            <ul>
                                <li>
                                    Nome:
                                    <span>
                                        <%= business.name %>
                                    </span>
                                </li>
                                <li>
                                    Cargo do Membro:
                                    <span>
                                        <%= business.role %>
                                    </span>
                                </li>
                                <li>
                                    Area de Negócio:
                                    <span>
                                        <%= business.area %>
                                    </span>
                                </li>
                                <li>
                                    Descrição:
                                    <span>
                                        <%= business.description %>
                                    </span>
                                </li>
                            </ul>
                        </div>
                        <div class="business-options">
                            <a class="btn btn-primary circle"
                                href="/admin/manage-accounts/member/<%= member.id %>/business/<%= business.id %>">
                                <img class="char" height="20" src="/assets/eye-icon.png">
                            </a>
                            <a class="btn btn-primary circle"
                                href="/admin/manage-accounts/member/<%= member.id %>/business/<%= business.id %>/edit">
                                <img class="char" height="20" src="/assets/edit-icon.png">
                            </a>
                            <form
                                action="/admin/manage-accounts/member/<%= member.id %>/business/<%= business._id %>/delete?_method=PATCH"
                                method="POST" onsubmit="return confirm('Tem certeza que deseja remover esta empresa?')">
                                <button class="btn btn-danger circle" type="submit">
                                    <img class="char" height="20" src="/assets/trash-can.png">
                                </button>
                            </form>
                        </div>
                    </div>
                    <!-- <img> -->
                    <% }) %>
                        <a class="btn btn-primary circle"
                            href="/admin/manage-accounts/member/<%= member.id %>/business">+</a>
            </div>
        </div>
    </div>
</div>