<div class="search-form-container">
    <form action="admin" method="GET">
        <label>Procurar Administrador</label>
        <div class="search-form">
            <input class="search-bar" type="text" name="name" placeholder="Admin Name" value="<%= searchOptions.name %>">
            <button class="btn btn-primary" type="submit">Procurar</button>
        </div>
    </form>
</div>
<br>
<div class="row">
    <% admin.forEach(admin => { %>
        <div class="container">
            <div>
                <%= admin.name %>
            </div>
            <div>
                <%= admin.email %>
            </div>
            <div>
                <%= admin.state %>
            </div>
            <div class="container-actions">
                <a href="/admin/manage-accounts/admin/<%= admin.id %>">Perfil</a>
                <a href="/admin/manage-accounts/admin/<%= admin.id %>/edit">Editar</a>
            </div>
        </div>
    <% }) %>
</div>