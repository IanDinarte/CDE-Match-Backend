<div class="search-form-container">
    <form action="admin" method="GET">
        <label>Procurar Administrador</label>
        <div class="search-form">
            <input class="search-bar" type="text" name="name" placeholder="Admin Name" value="<%= searchOptions.name %>">
            <button class="btn btn-primary" type="submit">Search</button>
        </div>
    </form>
</div>
<br>
<div class="row">
    <% admin.forEach(admin=> { %>
        <div class="container">
            <div>
                Nome: <%= admin.name %>
            </div>
            <div>
                Email: <%= admin.email %>
            </div>
            <div>
                Estado da Conta: <%= admin.state? "Ativo" : "Inativo" %>
            </div>
            <div class="container-actions">
                <a href="/admin/manage-accounts/admin/<%= admin.id %>">View</a>
                <a href="/admin/manage-accounts/admin/<%= admin.id %>/edit">Edit</a>
                <%- include('../../../partials/deleteForm.ejs', { url: `/admin/manage-accounts/admin/${admin.id}` }) %>
            </div>
        </div>
        <% }) %>
</div>