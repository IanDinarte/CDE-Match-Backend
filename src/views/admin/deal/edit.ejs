<div class="form-container">
    <h2>Editar Negócio</h2>
    <form action="/admin/manage-deals/<%= deal.id %>?_method=PATCH" method="POST">
        <div class="form-row">
            <%- include('_form_fields') %>
        </div>
        <div class="form-options">
            <button class="btn btn-primary" type="submit">Atualizar</button>
            <a class="btn btn-cancel" href="/admin/manage-deals/<%= deal.id %>">Cancelar</a>
        </div>
    </form>
</div>