<div class="form-container">
    <div class="form-column">
        <h2 class="name">
            <%= deal.title %>
        </h2>
        <div class="text-area" style="color: var(--color-minor-text); font-size: var(--font-minor-text-size);">
            <%= deal.description %>
        </div>
        <ul>
            <li>
                Tipo do Negócio:
                <span>
                    <%= deal.type %>
                </span>
            </li>
            <li>
                Area do Negócio:
                <span>
                    <%= deal.area %>
                </span>
            </li>
            <li>
                Valor Base:
                <span>
                    € <%= deal.price %>
                </span>
            </li>
            <li>
                Dono do Negócio:
                <span>
                    <a href="/admin/manage-accounts/member/<%= deal.owner %>">
                        <%= (deal.owner && deal.owner.name) ? deal.owner.name : 'Nome não encontrado' %>
                    </a>
                </span>
            </li>
            <li>
                Estado do Negócio:
                <span>
                    <%= deal.state %>
                </span>
            </li>
            <li>
                Interesses:
                <span>
                    <%= deal.interested.length %>
                </span>
            </li>
        </ul>
        <% if (deal.state === 'Disponivel' ) { %>
            <div class="form-item suggestion-box">
                <label>Sugerir este Negócio a um Membro</label>

                <form action="/admin/manage-deals/<%= deal.id %>/suggest" method="POST" class="suggestion-form">
                    <select name="suggestedTo" required class="suggestion-select">
                        <option value="" disabled selected>Escolha um membro...</option>
                        <% members.forEach(member=> { %>
                            <% if (member.id !==deal.owner.toString() && member.id !==deal.owner._id?.toString()) { %>
                                <option value="<%= member.id %>">
                                    <%= member.name %> (<%= member.city %>)
                                </option>
                                <% } %>
                                    <% }) %>
                    </select>
                    <button type="submit" class="btn btn-primary stream suggestion-btn">Sugerir</button>
                </form>
            </div>
            <% } %>
                <div class="form-options">
                    <a class="btn btn-primary" href="/admin/manage-deals/<%= deal.id %>/edit">Editar</a>
                    <% if(deal.state=='Cancelado' ){ %>
                        <%- include('../../partials/deleteForm.ejs', { url: `/admin/manage-deals/${deal.id}`}) %>
                            <% } %>
                </div>
    </div>
</div>